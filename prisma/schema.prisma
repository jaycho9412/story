generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String
  role         String     @default("user")
  createdAt    DateTime   @default(now())
  reviews      Review[]
  wishlists    Wishlist[]
}

model Novel {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  coverUrl    String?
  description String?
  booksUrl    String?
  createdAt   DateTime @default(now())
  reviews     Review[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  
  novel     Novel    @relation(fields: [novelId], references: [id])
  novelId   Int
}

model Wishlist {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  coverUrl    String?
  description String?
  booksUrl    String?
  status      String   @default("pending") // "pending" | "done"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
}
