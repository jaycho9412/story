generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int              @id @default(autoincrement())
  username         String           @unique
  passwordHash     String
  role             String           @default("user")
  createdAt        DateTime         @default(now())
  reviews          Review[]
  wishlists        Wishlist[]
  journals         Journal[]
  journalLikes     JournalLike[]
  profileComments  ProfileComment[] @relation("CommentAuthor")
  wallComments     ProfileComment[] @relation("ProfileOwner")
}

model Novel {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  coverUrl    String?
  description String?
  booksUrl    String?
  createdAt   DateTime @default(now())
  reviews     Review[]
  tags        Tag[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  novel     Novel    @relation(fields: [novelId], references: [id])
  novelId   Int
}

model Wishlist {
  id          Int      @id @default(autoincrement())
  title       String
  author      String?
  coverUrl    String?
  description String?
  booksUrl    String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  novels Novel[]
}

model Journal {
  id        Int           @id @default(autoincrement())
  title     String?
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id])
  userId    Int
  likes     JournalLike[]
}

model JournalLike {
  id        Int      @id @default(autoincrement())
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
  @@unique([journalId, userId])
}

model ProfileComment {
  id            Int      @id @default(autoincrement())
  content       String
  profileUserId Int
  profileUser   User     @relation("ProfileOwner", fields: [profileUserId], references: [id])
  author        User     @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId      Int
  createdAt     DateTime @default(now())
}
